# ═══════════════════════════════════════════════════════════════════════════════
# IMIS Environment Configuration
# Location : public_html/imis/.env
# ⚠  NEVER commit this file to version control.
# ⚠  Protected from web access by .htaccess — keep it inside public_html/imis/
# ═══════════════════════════════════════════════════════════════════════════════

# ── Database ────────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=u390694310_cscro8
DB_USER=u390694310_cscro8
DB_PASSWORD=civilService@ro08
DB_CHARSET=utf8mb4

# ── Application ─────────────────────────────────────────────────────────────────
APP_ENV=production
APP_NAME="IMIS - CSC RO VIII"
APP_URL=https://imis.cscro8.com
APP_DEBUG=false
APP_TIMEZONE=Asia/Manila

# ── Email / PHPMailer ───────────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=noreply@cscro8.gov.ph
MAIL_PASSWORD=your_smtp_app_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@cscro8.gov.ph
MAIL_FROM_NAME="IMIS CSC RO VIII"
MAIL_REPLY_TO=

# ── Security ────────────────────────────────────────────────────────────────────
CSRF_TOKEN_LIFETIME=3600
BCRYPT_COST=12

# Rate-limiting (brute-force protection)
# MAX_ATTEMPTS  : failed tries before lockout triggers
# WINDOW_SECONDS: rolling window those attempts are counted in  (900 s = 15 min)
# LOCKOUT_SECONDS: how long the lockout lasts after threshold   (1800 s = 30 min)
RATE_LIMIT_MAX_ATTEMPTS=5
RATE_LIMIT_WINDOW_SECONDS=900
RATE_LIMIT_LOCKOUT_SECONDS=1800

# ── Session ─────────────────────────────────────────────────────────────────────
SESSION_IDLE_TIMEOUT=3600
SESSION_REGEN_INTERVAL=600
SESSION_GC_MAXLIFETIME=3600
SESSION_COOKIE_LIFETIME=0
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Strict